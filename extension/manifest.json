{
    "manifest_version": 3,
    "name": "Fact Checker",
    "version": "1.0",
    "description": "Send selected page text to my local backend for analysis.",
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*"
    ],
    "content_scripts":[
    {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
    }
  ]
}